FROM debian:latest

RUN apt-get update && apt-get install -y --no-install-recommends bash curl tar gzip ca-certificates util-linux && rm -rf /var/lib/apt/lists/*

WORKDIR /tmp/vwbk-install
COPY install.sh vwbk ./
RUN bash install.sh

ENV PATH="/root/.local/bin:$PATH"

COPY test_vwbk.sh /tmp/test_vwbk.sh
COPY vwbk /root/.local/bin/vwbk
