#!/usr/bin/env bash

# vwbk - Bash-based Backup and Encryption Utility using post-quantum age
# Version: DEV (replaces with release tag in CI/CD)
VERSION="DEV"

show_help() {
  cat <<EOF
vwbk ${VERSION} - Post-Quantum age Backup Utility

Usage:
  vwbk enroll [filepath] [mode]
    Create a unified key archive (.vwbkey) containing public and encrypted private keys.
    mode: password | yubikey | fido2

  vwbk encrypt [key_path] [input_path] [output_folder]
    Tar, compress, and encrypt a file/folder with a public key (.pub) or key archive (.vwbkey).

  vwbk decrypt [input_path] [output_folder] [key_path]
    Decrypt and extract a backup. key_path is optional:
      - If provided, decrypts using a .vwbkey archive or password-encrypted .key file.
      - If omitted, automatically uses the companion key embedded inside the backup.

  vwbk inspect [backup_path]
    Show metadata for a given backup.

  vwbk update [version]
    Update vwbk to the latest version, or to a specified version (e.g. v1.7.9).

  vwbk help
    Show this help message.
EOF
}

# Subcommands routing
if [[ $# -lt 1 ]]; then
  show_help
  exit 1
fi

subcommand="$1"

case "$subcommand" in
  enroll)
    shift
    filepath=""
    mode=""

    # Parse arguments
    for arg in "$@"; do
      if [[ "$arg" == "password" || "$arg" == "yubikey" || "$arg" == "fido2" ]]; then
        mode="$arg"
      else
        filepath="$arg"
      fi
    done

    # Interactive prompts for missing arguments
    if [[ -z "$filepath" ]]; then
      read -p "Enter output path and name for the keys (e.g. ./mykeys): " filepath </dev/tty
    fi

    # Determine vwbkey file path
    if [[ "$filepath" == *.vwbkey ]]; then
      vwbkey_file="$filepath"
    else
      if [[ "$filepath" == */ || -z "$filepath" ]]; then
        if [[ -z "$filepath" ]]; then
          filepath="./"
        fi
        mkdir -p "$filepath"
        vwbkey_file="${filepath%/}/identity.vwbkey"
      else
        dir_name=$(dirname "$filepath")
        mkdir -p "$dir_name"
        vwbkey_file="${filepath}.vwbkey"
      fi
    fi

    # Create temporary directory for generating individual key files
    temp_key_dir=$(mktemp -d)
    key_base="${temp_key_dir}/key"

    if [[ -z "$mode" ]]; then
      while true; do
        read -p "Select enrollment mode (password/yubikey/fido2): " mode </dev/tty
        if [[ "$mode" == "password" || "$mode" == "yubikey" || "$mode" == "fido2" ]]; then
          break
        fi
        echo "Invalid mode. Please enter 'password', 'yubikey', or 'fido2'."
      done
    fi

    # Generate keypair using age-keygen -pq
    echo "Generating post-quantum age keypair..."
    keys=$(age-keygen -pq 2>/dev/null)
    if [[ $? -ne 0 ]]; then
      echo "Error: age-keygen -pq failed. Ensure age >= v1.3.0 is installed." >&2
      rm -rf "$temp_key_dir"
      exit 1
    fi

    # Parse keys
    pubkey=$(echo "$keys" | grep -o 'age1[a-z0-9]*')
    secretkey=$(echo "$keys" | grep '^AGE-SECRET-KEY-')

    if [[ -z "$pubkey" || -z "$secretkey" ]]; then
      echo "Error: Failed to parse generated keypair." >&2
      rm -rf "$temp_key_dir"
      exit 1
    fi

    if [[ "$mode" == "password" ]]; then
      echo "Encrypting private key with password..."
      echo "$secretkey" | age -p -o "${key_base}.key"
      if [[ $? -ne 0 ]]; then
        echo "Error: Encryption of private key failed." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      {
        echo "# vwbk_key_type: password"
        echo "$pubkey"
      } > "${key_base}.pub"

    elif [[ "$mode" == "yubikey" ]]; then
      if ! which age-plugin-yubikey >/dev/null 2>&1; then
        echo "Error: age-plugin-yubikey is not installed." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      echo ""
      echo "=== YubiKey Enrollment ==="
      echo "The YubiKey wizard will walk you through these steps:"
      echo "  1. Select your YubiKey (if multiple are plugged in)"
      echo "  2. Select a slot for the age identity (Slot 1 / Empty is fine)"
      echo "  3. Name the identity (optional, press Enter to skip)"
      echo "  4. Select a PIN policy:"
      echo "       - Always: PIN required every decryption (most secure)"
      echo "       - Once:   PIN required once per session (recommended)"
      echo "       - Never:  No PIN required"
      echo "  5. Select a touch policy:"
      echo "       - Always: Touch required every decryption (most secure)"
      echo "       - Cached: Touch required, cached for 15 seconds (recommended)"
      echo "       - Never:  No touch required"
      echo "  6. Confirm to generate the identity"
      echo ""
      echo "Insert your YubiKey now."
      echo ""
      # --generate prints identity to stdout (the interactive TUI writes to a file instead)
      hardware_setup=$(age-plugin-yubikey --generate)
      if [[ $? -ne 0 ]]; then
        echo "Error: age-plugin-yubikey failed." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      # Recipient line contains age1yubikey1...
      hw_recipient=$(echo "$hardware_setup" | grep -o 'age1yubikey1[a-z0-9]*')
      # Identity line starts with AGE-PLUGIN-YUBIKEY-
      hw_identity=$(echo "$hardware_setup" | grep '^AGE-PLUGIN-YUBIKEY-')
      if [[ -z "$hw_recipient" || -z "$hw_identity" ]]; then
        echo "Error: Failed to obtain YubiKey recipient/identity." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      echo "Encrypting post-quantum private key using YubiKey recipient..."
      echo "$secretkey" | age -r "$hw_recipient" -o "${key_base}.key"
      if [[ $? -ne 0 ]]; then
        echo "Error: Private key encryption with YubiKey failed." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      echo "$hw_identity" > "${key_base}.passkey"
      {
        echo "# vwbk_key_type: yubikey"
        echo "$pubkey"
      } > "${key_base}.pub"

    elif [[ "$mode" == "fido2" ]]; then
      if ! which age-plugin-fido2-hmac >/dev/null 2>&1; then
        echo "Error: age-plugin-fido2-hmac is not installed." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      echo ""
      echo "=== FIDO2 Enrollment ==="
      echo "The FIDO2 wizard will ask these questions in order:"
      echo ""
      echo "  1. Insert your FIDO2 security key when prompted"
      echo "  2. Touch your key when it blinks (credential is being created)"
      echo "  3. Enter your PIN (if your key has one)"
      echo ""
      echo "  4. Require a PIN for decryption? [y/n]"
      echo "     *** You MUST answer 'y' (yes) here. ***"
      echo "     If you answer 'n', the PIN is discarded and the next"
      echo "     step will fail with 'pin required' because your token"
      echo "     still needs the PIN for the final touch assertion."
      echo ""
      echo "  5. Touch your key again (HMAC secret is being derived)"
      echo ""
      echo "  6. Have a separate identity? [y/n]"
      echo "     Answer 'n' (no) if you don't want an extra identity file."
      echo ""
      echo "  7. Touch your key a final time"
      echo ""
      echo "Insert your FIDO2 key now."
      echo ""
      # -g is the correct flag for generating a new recipient/identity
      hardware_setup=$(age-plugin-fido2-hmac -g)
      if [[ $? -ne 0 ]]; then
        echo "Error: age-plugin-fido2-hmac failed." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      echo "Plugin output:"
      echo "$hardware_setup"
      echo ""
      # Public key line starts with '# public key:'
      hw_recipient=$(echo "$hardware_setup" | grep '# public key:' | awk '{print $NF}')
      # Identity line starts with AGE-PLUGIN-FIDO2-HMAC- (only present if user chose separate identity)
      hw_identity=$(echo "$hardware_setup" | grep '^AGE-PLUGIN-FIDO2-HMAC-')
      if [[ -z "$hw_recipient" ]]; then
        echo "Error: Failed to obtain FIDO2 recipient (public key)." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      echo "Encrypting post-quantum private key using FIDO2 recipient..."
      echo "$secretkey" | age -r "$hw_recipient" -o "${key_base}.key"
      if [[ $? -ne 0 ]]; then
        echo "Error: Private key encryption with FIDO2 key failed." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
      {
        echo "# vwbk_key_type: fido2"
        echo "$pubkey"
      } > "${key_base}.pub"
      if [[ -n "$hw_identity" ]]; then
        echo "$hw_identity" > "${key_base}.passkey"
      fi

    else
      echo "Error: Unknown mode '${mode}'. Use password, yubikey, or fido2." >&2
      rm -rf "$temp_key_dir"
      exit 1
    fi

    # Package individual keys into .vwbkey tar archive
    if [[ -f "${key_base}.key" && -f "${key_base}.pub" ]]; then
      tar -cf "$vwbkey_file" -C "$temp_key_dir" .
      if [[ $? -eq 0 ]]; then
        echo "----------------------------------------"
        echo "Keys successfully enrolled in a single archive!"
        echo "  Key Archive: ${vwbkey_file}"
        echo "  Identity Mode: ${mode}"
        echo "----------------------------------------"
        echo "Keep this single .vwbkey file safe. You will need it to encrypt and decrypt your backups."
      else
        echo "Error: Failed to package key files into tar archive." >&2
        rm -rf "$temp_key_dir"
        exit 1
      fi
    else
      echo "Error: Key generation failed or missing key files." >&2
      rm -rf "$temp_key_dir"
      exit 1
    fi
    rm -rf "$temp_key_dir"
    ;;

  encrypt)
    shift
    key_path=""
    input_path=""
    output_folder=""

    if [[ $# -ge 1 ]]; then key_path="$1"; fi
    if [[ $# -ge 2 ]]; then input_path="$2"; fi
    if [[ $# -ge 3 ]]; then output_folder="$3"; fi

    # Prompts for missing args
    if [[ -z "$key_path" ]]; then
      read -p "Enter key file path (.vwbkey or .pub): " key_path </dev/tty
    fi

    # Determine if key_path is a .vwbkey file or a standard .pub file
    temp_key_dir=""
    is_temp_key="false"

    if [[ -f "$key_path" ]]; then
      if [[ "$key_path" == *.vwbkey ]] || tar -tf "$key_path" >/dev/null 2>&1; then
        temp_key_dir=$(mktemp -d)
        is_temp_key="true"
        if ! tar -xf "$key_path" -C "$temp_key_dir" 2>/dev/null; then
          echo "Error: Failed to extract key archive '$key_path'." >&2
          rm -rf "$temp_key_dir"
          exit 1
        fi
        actual_key_path="${temp_key_dir}/key.pub"
      else
        actual_key_path="$key_path"
      fi
    else
      # Check if appending extensions works
      if [[ -f "${key_path}.vwbkey" ]]; then
        key_path="${key_path}.vwbkey"
        temp_key_dir=$(mktemp -d)
        is_temp_key="true"
        if ! tar -xf "$key_path" -C "$temp_key_dir" 2>/dev/null; then
          echo "Error: Failed to extract key archive '$key_path'." >&2
          rm -rf "$temp_key_dir"
          exit 1
        fi
        actual_key_path="${temp_key_dir}/key.pub"
      elif [[ -f "${key_path}.pub" ]]; then
        actual_key_path="${key_path}.pub"
      else
        echo "Error: Key file '$key_path' not found." >&2
        exit 1
      fi
    fi

    # Reject .key files — user probably meant the .pub file or .vwbkey
    if [[ "$actual_key_path" == *.key ]]; then
      base="${actual_key_path%.key}"
      if [[ -f "${base}.pub" ]]; then
        echo "Error: '$key_path' is a private key file. Use '${base}.pub' or the .vwbkey archive instead." >&2
      else
        echo "Error: '$key_path' is a private key file. Encryption requires the public key (.pub) or a key archive (.vwbkey)." >&2
      fi
      if [[ "$is_temp_key" == "true" ]]; then rm -rf "$temp_key_dir"; fi
      exit 1
    fi

    if [[ -z "$input_path" ]]; then
      read -p "Enter input folder or file path: " input_path </dev/tty
    fi
    if [[ ! -e "$input_path" ]]; then
      echo "Error: Input path '$input_path' does not exist." >&2
      if [[ "$is_temp_key" == "true" ]]; then rm -rf "$temp_key_dir"; fi
      exit 1
    fi

    if [[ -z "$output_folder" ]]; then
      read -p "Enter output folder path: " output_folder </dev/tty
    fi
    mkdir -p "$output_folder"

    # Set names and paths
    if [[ "$key_path" == *.vwbkey ]]; then
      key_name=$(basename "$key_path" .vwbkey)
    else
      key_name=$(basename "$actual_key_path" .pub)
    fi
    timestamp=$(date +%Y%m%d_%H%M%S)

    # Extract the actual public key (skip comment lines)
    pubkey_line=$(grep '^age1' "$actual_key_path")
    if [[ -z "$pubkey_line" ]]; then
      echo "Error: No public key found in '$key_path' (expected a line starting with 'age1')." >&2
      if [[ "$is_temp_key" == "true" ]]; then rm -rf "$temp_key_dir"; fi
      exit 1
    fi

    # Detect key type and companion key files
    companion_key=""
    companion_passkey=""
    if [[ "$is_temp_key" == "true" ]]; then
      companion_key="${temp_key_dir}/key.key"
      if [[ -f "${temp_key_dir}/key.passkey" ]]; then
        companion_passkey="${temp_key_dir}/key.passkey"
      fi
    else
      companion_key="${actual_key_path%.pub}.key"
      companion_passkey="${actual_key_path%.pub}.passkey"
    fi

    key_type=""
    if [[ -f "$companion_key" ]]; then
      # Try to detect by reading the first 10 lines of the age encrypted file
      if head -n 10 "$companion_key" | grep -q 'fido2-hmac'; then
        key_type="fido2"
      elif head -n 10 "$companion_key" | grep -q 'yubikey'; then
        key_type="yubikey"
      elif head -n 10 "$companion_key" | grep -q 'scrypt'; then
        key_type="password"
      fi
    fi

    if [[ -z "$key_type" ]]; then
      if grep -q 'vwbk_key_type: yubikey' "$actual_key_path"; then
        key_type="yubikey"
      elif grep -q 'vwbk_key_type: fido2' "$actual_key_path"; then
        key_type="fido2"
      elif grep -q 'vwbk_key_type: password' "$actual_key_path"; then
        key_type="password"
      fi
    fi

    if [[ -z "$key_type" ]]; then
      if echo "$pubkey_line" | grep -q 'age1yubikey1'; then
        key_type="yubikey"
      elif echo "$pubkey_line" | grep -q 'age1fido2'; then
        key_type="fido2"
      elif grep -q 'age-plugin-fido2-hmac' "$actual_key_path"; then
        key_type="fido2"
      else
        key_type="password"
      fi
    fi

    # Create temporary directory for backup packaging
    backup_tmp_dir=$(mktemp -d)
    meta_file="${backup_tmp_dir}/meta.txt"
    data_file="${backup_tmp_dir}/data.tar.gz.age"

    cat <<EOF > "$meta_file"
vwbk_version: ${VERSION}
key_name: ${key_name}
key_type: ${key_type}
timestamp: ${timestamp}
original_path: $(realpath "$input_path")
EOF

    has_embedded_key="false"
    if [[ -f "$companion_key" ]]; then
      cp "$companion_key" "${backup_tmp_dir}/identity.key"
      has_embedded_key="true"
    fi
    if [[ -f "$companion_passkey" ]]; then
      cp "$companion_passkey" "${backup_tmp_dir}/identity.passkey"
    fi
    echo "has_embedded_key: ${has_embedded_key}" >> "$meta_file"

    # Check if folder or file
    if [[ -d "$input_path" ]]; then
      echo "input_type: folder" >> "$meta_file"
      parent_dir=$(dirname "$(realpath "$input_path")")
      base_dir=$(basename "$(realpath "$input_path")")
      tar -czf - -C "$parent_dir" "$base_dir" | age -r "$pubkey_line" -o "$data_file"
      encrypt_status=("${PIPESTATUS[@]}")
    else
      echo "input_type: file" >> "$meta_file"
      parent_dir=$(dirname "$(realpath "$input_path")")
      base_file=$(basename "$(realpath "$input_path")")
      tar -czf - -C "$parent_dir" "$base_file" | age -r "$pubkey_line" -o "$data_file"
      encrypt_status=("${PIPESTATUS[@]}")
    fi

    if [[ ${encrypt_status[0]} -eq 0 && ${encrypt_status[1]} -eq 0 ]]; then
      backup_file="${output_folder}/${timestamp}-${key_name}.vwbk"
      tar -cf "$backup_file" -C "$backup_tmp_dir" .
      if [[ $? -eq 0 ]]; then
        echo "Backup successfully created at: $backup_file"
      else
        echo "Error: Failed to create tar archive." >&2
        rm -f "$backup_file"
        rm -rf "$backup_tmp_dir"
        if [[ "$is_temp_key" == "true" ]]; then rm -rf "$temp_key_dir"; fi
        exit 1
      fi
    else
      echo "Error: Encryption or archiving failed." >&2
      rm -rf "$backup_tmp_dir"
      if [[ "$is_temp_key" == "true" ]]; then rm -rf "$temp_key_dir"; fi
      exit 1
    fi
    rm -rf "$backup_tmp_dir"
    if [[ "$is_temp_key" == "true" ]]; then
      rm -rf "$temp_key_dir"
    fi
    ;;

  decrypt)
    shift
    input_path=""
    output_folder=""
    key_path=""

    # New arg order: [input_path] [output_folder] [key_path]
    if [[ $# -ge 1 ]]; then input_path="$1"; fi
    if [[ $# -ge 2 ]]; then output_folder="$2"; fi
    if [[ $# -ge 3 ]]; then key_path="$3"; fi

    # Prompt for input backup path
    if [[ -z "$input_path" ]]; then
      read -p "Enter path to backup file (.vwbk): " input_path </dev/tty
    fi
    if [[ ! -e "$input_path" ]]; then
      echo "Error: Input path '$input_path' does not exist." >&2
      exit 1
    fi

    # Determine if directory (old format) or file (new format)
    temp_dir=""
    is_temp_dir="false"

    if [[ -d "$input_path" ]]; then
      temp_dir="$input_path"
    elif [[ -f "$input_path" ]]; then
      temp_dir=$(mktemp -d)
      is_temp_dir="true"
      if ! tar -xf "$input_path" -C "$temp_dir" 2>/dev/null; then
        echo "Error: Failed to extract backup archive '$input_path'." >&2
        rm -rf "$temp_dir"
        exit 1
      fi
    else
      echo "Error: Input path '$input_path' is neither a file nor a directory." >&2
      exit 1
    fi

    if [[ ! -f "${temp_dir}/data.tar.gz.age" ]]; then
      echo "Error: Backup is not a valid vwbk backup (missing data.tar.gz.age)." >&2
      if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
      exit 1
    fi

    # Prompt for output folder
    if [[ -z "$output_folder" ]]; then
      read -p "Enter destination output folder: " output_folder </dev/tty
    fi
    mkdir -p "$output_folder"

    # If key_path is not specified, check if companion key is inside the backup
    if [[ -z "$key_path" ]]; then
      if [[ -f "${temp_dir}/identity.key" ]]; then
        key_path="${temp_dir}/identity.key"
      fi
    fi

    # Determine if key_path is a .vwbkey file
    is_temp_key_decrypt="false"
    temp_key_dir_decrypt=""

    if [[ -n "$key_path" && "$key_path" != "${temp_dir}/identity.key" ]]; then
      if [[ -f "$key_path" ]]; then
        if [[ "$key_path" == *.vwbkey ]] || tar -tf "$key_path" >/dev/null 2>&1; then
          temp_key_dir_decrypt=$(mktemp -d)
          is_temp_key_decrypt="true"
          if ! tar -xf "$key_path" -C "$temp_key_dir_decrypt" 2>/dev/null; then
            echo "Error: Failed to extract key archive '$key_path'." >&2
            rm -rf "$temp_key_dir_decrypt"
            if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
            exit 1
          fi
          key_path="${temp_key_dir_decrypt}/key.key"
        fi
      else
        # Check if appending extensions works
        if [[ -f "${key_path}.vwbkey" ]]; then
          key_path="${key_path}.vwbkey"
          temp_key_dir_decrypt=$(mktemp -d)
          is_temp_key_decrypt="true"
          if ! tar -xf "$key_path" -C "$temp_key_dir_decrypt" 2>/dev/null; then
            echo "Error: Failed to extract key archive '$key_path'." >&2
            rm -rf "$temp_key_dir_decrypt"
            if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
            exit 1
          fi
          key_path="${temp_key_dir_decrypt}/key.key"
        fi
      fi
    fi

    # Determine decrypt mode: if key_path given and not extracted/embedded, use password flow.
    # Otherwise, read key_type from meta.txt or ask interactively.
    if [[ -n "$key_path" && "$key_path" != "${temp_dir}/identity.key" && "$is_temp_key_decrypt" != "true" ]]; then
      decrypt_mode="password"
    else
      # Try to read key_type from meta.txt
      meta_key_type=""
      if [[ -f "${temp_dir}/meta.txt" ]]; then
        meta_key_type=$(grep '^key_type:' "${temp_dir}/meta.txt" | awk '{print $2}')
      fi

      if [[ -n "$meta_key_type" ]]; then
        decrypt_mode="$meta_key_type"
        echo "Detected key type from backup metadata: ${decrypt_mode}"
      else
        # Interactive selection
        echo "No key path provided. How was this backup encrypted?" >/dev/tty
        echo "  1) Password-encrypted key file (.key)" >/dev/tty
        echo "  2) YubiKey hardware passkey" >/dev/tty
        echo "  3) FIDO2 hardware passkey" >/dev/tty
        while true; do
          read -p "Select decryption method [1/2/3]: " choice </dev/tty
          case "$choice" in
            1) decrypt_mode="password"; break ;;
            2) decrypt_mode="yubikey";  break ;;
            3) decrypt_mode="fido2";    break ;;
            *) echo "Please enter 1, 2, or 3." >/dev/tty ;;
          esac
        done
      fi
    fi

    # Execute the appropriate decryption flow
    case "$decrypt_mode" in
      password)
        if [[ -z "$key_path" ]]; then
          read -p "Enter private key file path (.key): " key_path </dev/tty
        fi
        if [[ ! -f "$key_path" ]]; then
          if [[ -f "${key_path}.key" ]]; then
            key_path="${key_path}.key"
          else
            echo "Error: Private key file '$key_path' not found." >&2
            if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
            if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
            exit 1
          fi
        fi
        echo "Decrypting backup with password-encrypted private key..."
        age -d "$key_path" | age -d -i - -o - "${temp_dir}/data.tar.gz.age" | tar -xzf - -C "$output_folder"
        pipe_status=("${PIPESTATUS[@]}")
        ;;

      yubikey)
        if ! which age-plugin-yubikey >/dev/null 2>&1; then
          echo "Error: age-plugin-yubikey is not installed." >&2
          if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
          if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
          exit 1
        fi
        if [[ -z "$key_path" ]]; then
          read -p "Enter encrypted private key file path (.key): " key_path </dev/tty
        fi
        if [[ ! -f "$key_path" ]]; then
          echo "Error: Private key file '$key_path' not found." >&2
          if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
          if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
          exit 1
        fi
        # Check for companion .passkey identity file
        if [[ "$key_path" == "${temp_dir}/identity.key" && -f "${temp_dir}/identity.passkey" ]]; then
          passkey_file="${temp_dir}/identity.passkey"
        elif [[ "$is_temp_key_decrypt" == "true" && -f "${temp_key_dir_decrypt}/key.passkey" ]]; then
          passkey_file="${temp_key_dir_decrypt}/key.passkey"
        else
          passkey_file="${key_path%.key}.passkey"
          if [[ ! -f "$passkey_file" ]]; then
            read -p "Enter YubiKey identity file path (.passkey): " passkey_file </dev/tty
          fi
        fi
        if [[ ! -f "$passkey_file" ]]; then
          echo "Error: YubiKey identity file '$passkey_file' not found." >&2
          if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
          if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
          exit 1
        fi
        echo "Decrypting with YubiKey passkey (touch your key when prompted)..."
        # age-plugin-yubikey needs an interactive TTY; run age with /dev/tty as stdin
        age -d -i "$passkey_file" "$key_path" | age -d -i - -o - "${temp_dir}/data.tar.gz.age" | tar -xzf - -C "$output_folder"
        pipe_status=("${PIPESTATUS[@]}")
        ;;

      fido2)
        if ! which age-plugin-fido2-hmac >/dev/null 2>&1; then
          echo "Error: age-plugin-fido2-hmac is not installed." >&2
          if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
          if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
          exit 1
        fi
        if [[ -z "$key_path" ]]; then
          read -p "Enter encrypted private key file path (.key): " key_path </dev/tty
        fi
        if [[ ! -f "$key_path" ]]; then
          echo "Error: Private key file '$key_path' not found." >&2
          if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
          if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
          exit 1
        fi
        
        # Check for companion .passkey identity file
        if [[ "$key_path" == "${temp_dir}/identity.key" && -f "${temp_dir}/identity.passkey" ]]; then
          passkey_file="${temp_dir}/identity.passkey"
        elif [[ "$is_temp_key_decrypt" == "true" && -f "${temp_key_dir_decrypt}/key.passkey" ]]; then
          passkey_file="${temp_key_dir_decrypt}/key.passkey"
        else
          passkey_file="${key_path%.key}.passkey"
        fi

        if [[ -f "$passkey_file" ]]; then
          echo "Decrypting with FIDO2 passkey (touch your security key when prompted)..."
          age -d -i "$passkey_file" "$key_path" | age -d -i - -o - "${temp_dir}/data.tar.gz.age" | tar -xzf - -C "$output_folder"
        else
          echo "No .passkey file found. Decrypting with FIDO2 token directly..."
          echo "You will need to insert your FIDO2 key and touch it when prompted."
          age -d -j fido2-hmac -o - "$key_path" | age -d -i - -o - "${temp_dir}/data.tar.gz.age" | tar -xzf - -C "$output_folder"
        fi
        pipe_status=("${PIPESTATUS[@]}")
        ;;

      *)
        echo "Error: Unknown decryption mode '${decrypt_mode}'." >&2
        if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
        if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
        exit 1
        ;;
    esac

    if [[ ${pipe_status[0]} -eq 0 && ${pipe_status[1]} -eq 0 ]]; then
      echo "Backup successfully decrypted to: $output_folder"
      cp "${temp_dir}/meta.txt" "${output_folder}/vwbk-meta.txt"
    else
      echo "Error: Decryption or extraction failed." >&2
      if [[ "$is_temp_dir" == "true" ]]; then rm -rf "$temp_dir"; fi
      if [[ "$is_temp_key_decrypt" == "true" ]]; then rm -rf "$temp_key_dir_decrypt"; fi
      exit 1
    fi

    if [[ "$is_temp_dir" == "true" ]]; then
      rm -rf "$temp_dir"
    fi
    if [[ "$is_temp_key_decrypt" == "true" ]]; then
      rm -rf "$temp_key_dir_decrypt"
    fi
    ;;

  inspect)
    shift
    backup_path=""
    if [[ $# -ge 1 ]]; then backup_path="$1"; fi

    if [[ -z "$backup_path" ]]; then
      read -p "Enter backup path (.vwbk): " backup_path </dev/tty
    fi

    if [[ ! -e "$backup_path" ]]; then
      echo "Error: Backup path '$backup_path' does not exist." >&2
      exit 1
    fi

    if [[ -d "$backup_path" ]]; then
      meta_file="${backup_path}/meta.txt"
      if [[ ! -f "$meta_file" ]]; then
        echo "Error: No meta.txt found in '$backup_path'." >&2
        exit 1
      fi
      echo "=== VWBK Backup Metadata ==="
      cat "$meta_file"
      echo "============================"
    elif [[ -f "$backup_path" ]]; then
      meta_content=$(tar -O -xf "$backup_path" ./meta.txt 2>/dev/null || tar -O -xf "$backup_path" meta.txt 2>/dev/null)
      if [[ -z "$meta_content" ]]; then
        echo "Error: No meta.txt found in backup '$backup_path'." >&2
        exit 1
      fi
      echo "=== VWBK Backup Metadata ==="
      echo "$meta_content"
      echo "============================"
    else
      echo "Error: Backup path '$backup_path' is neither a file nor a directory." >&2
      exit 1
    fi
    ;;

  update)
    shift
    target_version=""
    if [[ $# -ge 1 ]]; then target_version="$1"; fi

    target_path=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")

    if [[ -z "$target_version" ]]; then
      echo "Fetching latest version from GitHub cwhde/vwbk..."
      latest_json=$(curl -sSfL https://api.github.com/repos/cwhde/vwbk/releases/latest 2>/dev/null)
      target_version=$(echo "$latest_json" | grep -o '"tag_name":"[^"]*"' | head -n 1 | cut -d'"' -f4)
      if [[ -z "$target_version" ]]; then
        echo "Error: Could not retrieve latest version from GitHub." >&2
        exit 1
      fi
    else
      if [[ "$target_version" != v* ]]; then
        target_version="v${target_version}"
      fi
    fi

    if [[ "$VERSION" == "$target_version" ]]; then
      echo "vwbk is already at version ${target_version}."
      exit 0
    fi

    echo "Downloading vwbk ${target_version}..."
    download_url="https://github.com/cwhde/vwbk/releases/download/${target_version}/vwbk"
    tmp_file=$(mktemp)
    if ! curl -sSfL "$download_url" -o "$tmp_file"; then
      echo "Error: Failed to download vwbk version ${target_version} from ${download_url}." >&2
      rm -f "$tmp_file"
      exit 1
    fi

    # Verify that the downloaded file is a valid script
    if ! head -n 1 "$tmp_file" | grep -q '^#!/'; then
      echo "Error: Downloaded file is not a valid bash script." >&2
      rm -f "$tmp_file"
      exit 1
    fi

    chmod +x "$tmp_file"
    if [ -w "$target_path" ]; then
      mv "$tmp_file" "$target_path"
    else
      echo "Write permission denied for '$target_path'. Attempting with sudo..."
      if which sudo >/dev/null 2>&1; then
        sudo mv "$tmp_file" "$target_path"
      else
        echo "Error: Cannot write to '$target_path'. Please run with sudo or as root." >&2
        rm -f "$tmp_file"
        exit 1
      fi
    fi
    echo "vwbk successfully updated to ${target_version}."
    ;;

  help)
    show_help
    ;;

  *)
    echo "Error: Unknown subcommand '$subcommand'." >&2
    show_help
    exit 1
    ;;
esac
